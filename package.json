{
  "name": "@interop/ed25519-verification-key",
  "version": "6.1.1",
  "description": "TypeScript/JavaScript library for generating and working with Ed25519 key pairs; supports Multikey (default), Ed25519VerificationKey2020, Ed25519VerificationKey2018, and JsonWebKey2020 serializations.",
  "type": "module",
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run lint && pnpm run test-node && pnpm run test-browser",
    "test-browser": "playwright test",
    "test-node": "vitest run",
    "test-coverage": "vitest run --coverage"
  },
  "homepage": "https://github.com/interop-alliance/ed25519-verification-key",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/ed25519-verification-key.git"
  },
  "license": "BSD-3-Clause",
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "browser": {
    "buffer": false,
    "crypto": false,
    "util": false,
    "./src/ed25519.ts": "./src/ed25519-browser.ts",
    "./dist/ed25519.js": "./dist/ed25519-browser.js"
  },
  "react-native": {
    "buffer": false,
    "crypto": false,
    "util": false,
    "./src/ed25519.ts": "./src/ed25519-reactnative.ts",
    "./dist/ed25519.js": "./dist/ed25519-reactnative.js"
  },
  "dependencies": {
    "@digitalcredentials/keypair": "^3.0.0",
    "@digitalcredentials/ssi": "^5.4.2",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jose": "^4.11.1",
    "multibase": "^4.0.4",
    "multicodec": "^3.0.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  }
}
